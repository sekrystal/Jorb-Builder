{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Builder Memory Store",
  "type": "object",
  "required": [
    "generated_at",
    "entries",
    "artifact_index"
  ],
  "properties": {
    "generated_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "memory_id",
          "memory_type",
          "ticket_family",
          "source_artifact",
          "timestamp",
          "confidence",
          "freshness",
          "observation",
          "inference",
          "primary_basis",
          "relevance_tags",
          "origin",
          "status",
          "provenance"
        ],
        "properties": {
          "memory_id": {"type": "string"},
          "memory_type": {"type": "string"},
          "ticket_family": {"type": "string"},
          "task_id": {"type": ["string", "null"]},
          "area": {"type": "string"},
          "source_artifact": {"type": "string"},
          "timestamp": {"type": ["string", "null"]},
          "confidence": {"type": "number"},
          "freshness": {"type": "object"},
          "observation": {"type": "string"},
          "inference": {"type": "string"},
          "primary_basis": {"type": "string"},
          "relevance_tags": {
            "type": "array",
            "items": {"type": "string"}
          },
          "origin": {"type": "string"},
          "status": {"type": "string"},
          "status_reason": {"type": "string"},
          "provenance": {
            "type": "array",
            "items": {"type": "object"}
          }
        }
      }
    },
    "artifact_index": {
      "type": "object",
      "required": [
        "generated_at",
        "entries",
        "counts_by_label",
        "counts_by_kind",
        "by_task_id",
        "by_label",
        "by_name"
      ],
      "properties": {
        "generated_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "artifact_id",
              "task_id",
              "ticket_family",
              "history_path",
              "run_log_dir",
              "path",
              "relative_path",
              "artifact_name",
              "artifact_stem",
              "extension",
              "kind",
              "size_bytes",
              "timestamp",
              "history_status",
              "labels",
              "phase4_artifact",
              "search_tokens"
            ],
            "properties": {
              "artifact_id": {"type": "string"},
              "task_id": {"type": ["string", "null"]},
              "ticket_family": {"type": "string"},
              "history_path": {"type": "string"},
              "run_log_dir": {"type": ["string", "null"]},
              "path": {"type": "string"},
              "relative_path": {"type": "string"},
              "artifact_name": {"type": "string"},
              "artifact_stem": {"type": "string"},
              "extension": {"type": "string"},
              "kind": {"type": "string"},
              "size_bytes": {"type": ["integer", "null"]},
              "timestamp": {"type": ["string", "null"]},
              "history_status": {"type": "string"},
              "labels": {
                "type": "array",
                "items": {"type": "string"}
              },
              "phase4_artifact": {"type": "boolean"},
              "search_tokens": {
                "type": "array",
                "items": {"type": "string"}
              }
            }
          }
        },
        "counts_by_label": {"type": "object"},
        "counts_by_kind": {"type": "object"},
        "by_task_id": {"type": "object"},
        "by_label": {"type": "object"},
        "by_name": {"type": "object"}
      }
    }
  }
}
